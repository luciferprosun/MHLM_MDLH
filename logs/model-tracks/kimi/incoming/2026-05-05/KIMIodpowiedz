    """Fenomenologiczne parametry LSC"""
    alpha_iso: float = 0.0      # Izotropowa korekta [Tr(D)]
    alpha_aniso: float = 0.0    # Anizotropowa korekta [D_{(aniso)}]
    Lambda: float = 20.0        # Skala EFT [MeV]
    c1: float = 0.7             # Współczynnik Wilsona (izotropowy)
    c2: float = 0.3             # Współczynnik Wilsona (anizotropowy)
    
    @property
    def delta_iso(self) -> float:
        """Izotropowy deficyt dla E=1 MeV"""
        return (3 * self.c1 * 1.0) / self.Lambda
    
    @property
    def delta_aniso_amplitude(self) -> float:
        """Amplituda anizotropii dla E=1 MeV"""
        return (self.c2 * 1.0) / self.Lambda

class LikelihoodFramework:
    """Framework bayesowski do globalnego fitu"""
    
    def __init__(self):
        # ————— DANE BEST (Gallium) —————
        # Korekta z papieru BEST 2022
        self.best_obs = 0.79      # R = obserwowane/oczekiwane
        self.best_err = 0.05       # Błąd statystyczny
        self.best_syst = 0.03      # Błąd systematyczny (aktywność źródła, przekrój)
        
        # ————— DANE KATRIN (Tritium beta decay) —————
        self.katrin_limit = 0.01   # Limit na odchylenie spektralne <1%
        
        # ————— DANE IceCube (Anizotropia kierunkowa) —————
        self.icecube_limit = 1e-3  # Limit górny na anizotropię przy TeV
        
        # ————— DANE REAKTOROWE (Daya Bay, KamLAND) —————
        self.flux_ratio = 0.98     # Zgodność z SM w ramach błędów
        self.flux_err = 0.02
        
    def poisson_likelihood_best(self, alpha_iso: float) -> float:
        """
        Likelihood Poissona dla eksperymentu BEST
        
        N_obs = obserwowana liczba zdarzeń
        N_exp = oczekiwana liczba (SM + korekta LSC)
        """
        # Korekta LSC dla ν_e z gal (E ~ 1 MeV)
        correction = 1 + alpha_iso
        
        # Model: R_pred = (SM + LSC) / SM = 1 + correction
        R_pred = 1.0 + correction  # alpha_iso ujemne daje R<1
        
        # Likelihood Poissona (aproksymacja Gaussem dla dużych N)
        # Uwzględniamy błędy systematyczne przez rozszerzenie wariancji
        variance = self.best_err**2 + self.best_syst**2
        log_likelihood = -0.5 * ((self.best_obs - R_pred)**2 / variance)
        
        return log_likelihood
    
    def prior_bayesian(self, params: LSCParameters) -> float:
        """
        Priory bayesowskie (konserwatywne)
        
        Zakresy: alpha_iso ∈ [-0.1, 0.1]  (deficyt do 10%)
                 alpha_aniso ∈ [-0.1, 0.1]
                 Λ ∈ [1, 100] MeV
                 c_i ∈ [0, 2]
        """
        log_prior = 0.0
        
        # Uniform priors dla alpha
        if not (-0.1 <= params.alpha_iso <= 0.1):
            return -np.inf
        if not (-0.1 <= params.alpha_aniso <= 0.1):
            return -np.inf
            
        # Log-uniform prior dla Λ (skala nowej fizyki)
        if 1.0 <= params.Lambda <= 100.0:
            log_prior += -np.log(params.Lambda)  # Jeffreys prior
        else:
            return -np.inf
            
        # Uniform prior dla c1, c2
        if not (0.0 <= params.c1 <= 2.0):
            return -np.inf
        if not (0.0 <= params.c2 <= 2.0):
            return -np.inf
            
        return log_prior
    
    def katrin_constraint(self, alpha_iso: float) -> float:
        """
        Więzy z KATRIN na odchylenie spektralne
        
        KATRIN mierzy spektrum trytu z precyzją 0.1% 
        dla E < 18.6 keV
        """
        # Dla E ~ 10 keV, E/Λ ~ 0.5 (jeśli Λ=20 MeV)
        correction = alpha_iso * (10.0 / 20.0)  # skalowanie z energią
        
        if abs(correction) > self.katrin_limit:
            return -10.0  # Silna kara
        return 0.0
    
    def icecube_constraint(self, alpha_aniso: float) -> float:
        """
        Więzy z IceCube na anizotropię kierunkową przy TeV
        
        Dla IceCube: E ~ 1 TeV = 10^6 MeV
        Jeśli Λ ~ 20 MeV → E/Λ = 50000
        """
        E_TeV = 1e6  # MeV
        Lambda_guess = 20.0  # MeV
        
        # Anizotropia przewidywana przez LSC
        anisotropy_pred = alpha_aniso * (E_TeV / Lambda_guess)
        
        # Limit IceCube: < 0.1%
        if anisotropy_pred > self.icecube_limit:
            # Konflikt! Potrzebne dostrojenie
            penalty = -abs(anisotropy_pred / self.icecube_limit)
            return penalty
        
        return 0.0
    
    def reactor_constraint(self, alpha_iso: float) -> float:
        """
        Więzy z eksperymentów reaktorowych (Daya Bay, KamLAND)
        
        Obserwowany strumień ν_e z reaktorów zgodny z SM w granicach 2%
        """
        # Reaktory: E ~ 3-4 MeV
        correction = alpha_iso * (3.5 / 20.0)  # E/Λ dla Λ=20 MeV
        
        # Zgodność z danymi
        chi2 = ((self.flux_ratio - (1 + correction))**2) / self.flux_err**2
        
        if chi2 > 4.0:  # >2σ odchylenie
            return -chi2/2.0
        return 0.0
    
    def total_log_posterior(self, params: LSCParameters) -> float:
        """
        Całkowity log-posterior = log(likelihood) + log(prior) + constraints
        """
        log_post = 0.0
        
        # Likelihood z danych BEST
        log_post += self.poisson_likelihood_best(params.alpha_iso)
        
        # Priory
        log_post += self.prior_bayesian(params)
        
        # Więzy eksperymentalne
        log_post += self.katrin_constraint(params.alpha_iso)
        log_post += self.icecube_constraint(params.alpha_aniso)
        log_post += self.reactor_constraint(params.alpha_iso)
        
        return log_post

class MCMCSampler:
    """Prosty sampler MCMC do eksploracji przestrzeni parametrów"""
    
    def __init__(self, likelihood_framework, n_walkers=32, n_steps=5000):
        self.lf = likelihood_framework
        self.n_walkers = n_walkers
        self.n_steps = n_steps
        
    def run(self, initial_params: LSCParameters):
        """
        Uruchom MCMC (Metropolis-Hastings)
        
        Returns:
            samples: Tablica z próbkami posteriors
        """
        n_dim = 4  # alpha_iso, alpha_aniso, c1, c2
        samples = np.zeros((self.n_steps, n_dim))
        
        # Inicjalizacja
        current = np.array([initial_params.alpha_iso,
                           initial_params.alpha_aniso,
                           initial_params.c1,
                           initial_params.c2])
        
        current_log_post = self.lf.total_log_posterior(initial_params)
        
        # Propozycja (krok losowy)
        step_size = np.array([0.01, 0.01, 0.1, 0.1])
        
        for i in range(self.n_steps):
            # Generuj propozycję
            proposal = current + step_size * np.random.randn(n_dim)
            proposal_params = LSCParameters(alpha_iso=proposal[0],
                                           alpha_aniso=proposal[1],
                                           c1=proposal[2],
                                           c2=proposal[3],
                                           Lambda=20.0)  # Stałe Λ w tej wersji
            
            # Oblicz log-posterior dla propozycji
            proposal_log_post = self.lf.total_log_posterior(proposal_params)
            
            # Metropolis-Hastings acceptance
            if np.log(np.random.rand()) < (proposal_log_post - current_log_post):
                current = proposal
                current_log_post = proposal_log_post
            
            samples[i] = current
            
        return samples

# ————— KOD DO URUCHOMIENIA —————
if __name__ == "__main__":
    # Inicjalizacja frameworku
    lf = LikelihoodFramework()
    
    # Parametry początkowe (zgodne z BEST)
    init_params = LSCParameters(alpha_iso=-0.07,  # Deficyt 7%
                                alpha_aniso=0.02, # Mała anizotropia
                                c1=0.7,
                                c2=0.3,
                                Lambda=20.0)
    
    # Oblicz log-posterior
    log_post = lf.total_log_posterior(init_params)
    print(f"Initial log-posterior: {log_post:.2f}")
    
    # MCMC sampling
    sampler = MCMCSampler(lf)
    samples = sampler.run(init_params)
    
    # Podstawowe statystyki
    alpha_iso_mean = np.mean(samples[:, 0])
    alpha_iso_std = np.std(samples[:, 0])
    
    print(f"\n=== WYNIKI FITU ===")
    print(f"α_iso = {alpha_iso_mean:.4f} ± {alpha_iso_std:.4f}")
    print(f"Predykowany deficyt: {alpha_iso_mean*100:.1f}%")
    print(f"Zgodność z BEST (R={lf.best_obs}): {1+alpha_iso_mean:.3f}")
    
    # Zapisz wyniki
    np.savetxt("mcmc_samples.txt", samples, 
               header="alpha_iso alpha_aniso c1 c2")
